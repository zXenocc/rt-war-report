    {
      "parameters": {
        "jsCode": "// 1. ดึงข้อมูล Static Data สำหรับเช็คข่าวซ้ำ\nconst staticData = $getWorkflowStaticData('global');\nconst currentOutput = $input.first().json.output ?? '';\nconst previousOutput = staticData.lastSentOutput ?? '';\n\n// 2. ตรวจสอบที่มาของ Execution แบบปลอดภัย\nlet webhookData = null;\ntry {\n  // ใช้ดัชนี [0] และเช็คความผิดพลาดเพื่อไม่ให้ Node พัง\n  webhookData = $('Webhook1').first();\n} catch (e) {\n  // ถ้าไม่มีข้อมูลจาก Webhook (เช่น รันจาก Schedule) จะมาตกที่นี่\n  webhookData = null;\n}\n\nconst isWebhook = webhookData !== null;\nconst isNew = currentOutput.trim() !== previousOutput.trim();\n\n// 3. กำหนด Logic การตัดสินใจ\nlet shouldProceed = false;\nlet replyToken = null;\n\nif (isWebhook) {\n  // ถ้ามาจาก Webhook ให้ผ่านตลอด และดึง replyToken\n  shouldProceed = true;\n  replyToken = webhookData.json.body.events[0].replyToken;\n} else if (isNew) {\n  // ถ้ามาจาก Schedule ให้ผ่านเฉพาะข่าวใหม่ และอัปเดต static data\n  shouldProceed = true;\n  staticData.lastSentOutput = currentOutput;\n}\n\n// 4. ส่งข้อมูลออกไปยัง Node ถัดไป\nreturn [{\n  json: {\n    output: currentOutput,\n    isNew: shouldProceed,\n    replyToken: replyToken\n  }\n}];"
      },
